<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- _________________________ Application Settings _________________________ -->

	<app title="Bob's Onslaught"
	     file="BOB"
	     packageName="com.ninjamuffin99.funkinbob"
	     package="com.ninjamuffin99.funkinbob"
	     main="Main"
	     version="0.2.7.1"
	     company="ninjamuffin99" />

	<set name="APP_ID" value="0x0100f6c013bbc000" />
	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />

	<!-- __________________________ Android Settings ___________________________ -->

	<android targetSdkVersion="33" minSdkVersion="21" if="android" />

	<!--
		Duas tags separadas — lime não aceita "armv7,arm64" numa só tag.
	-->
	<architecture name="armv7" if="android" />
	<architecture name="arm64" if="android" />

	<!-- Permissões Android -->
	<permission name="android.permission.INTERNET"               if="android" />
	<permission name="android.permission.VIBRATE"                if="android" />
	<permission name="android.permission.READ_EXTERNAL_STORAGE"  if="android" />
	<permission name="android.permission.WRITE_EXTERNAL_STORAGE" if="android" />

	<!-- __________________________ iOS Settings _______________________________ -->

	<ios deployment="12" if="ios" />

	<!-- __________________________ Window Settings ___________________________ -->

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="html5"    resizable="true" />
	<window if="desktop"  orientation="landscape" fullscreen="false" resizable="true" vsync="false" />
	<window if="mobile"   orientation="landscape" fullscreen="true"  width="0" height="0" resizable="false" />
	<window if="switch"   orientation="landscape" fullscreen="true"  width="0" height="0" resizable="true" />

	<!-- ___________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="exportJon/debug"   if="debug" />
	<set name="BUILD_DIR" value="exportJon/release" unless="debug" />
	<set name="BUILD_DIR" value="exportJon/32bit"   if="32bit" />

	<classpath name="sourceJon" />

	<!-- __________________________ Asset Settings ____________________________ -->

	<!-- Preload assets -->
	<assets path="assets/preload" rename="assets" exclude="*.ogg" if="web" />
	<assets path="assets/preload" rename="assets" exclude="*.ogg" if="ios" />
	<assets path="assets/preload" rename="assets" exclude="*.mp3" if="android" />
	<assets path="assets/preload" rename="assets" exclude="*.mp3" if="desktop" />

	<!-- PRELOAD_ALL apenas em desktop/switch; mobile força NO_PRELOAD_ALL -->
	<define name="PRELOAD_ALL"    if="desktop" />
	<define name="PRELOAD_ALL"    if="switch"  />
	<define name="NO_PRELOAD_ALL" if="mobile"  />
	<define name="NO_PRELOAD_ALL" if="web"     />

	<section if="PRELOAD_ALL">
		<library name="songs"  preload="true" />
		<library name="shared" preload="true" />
		<library name="week2"  preload="true" />
		<library name="week3"  preload="true" />
		<library name="week4"  preload="true" />
		<library name="week5"  preload="true" />
	</section>

	<section if="NO_PRELOAD_ALL">
		<library name="songs"  preload="false" />
		<library name="shared" preload="false" />
		<library name="week2"  preload="false" />
		<library name="week3"  preload="false" />
		<library name="week4"  preload="false" />
		<library name="week5"  preload="false" />
	</section>

	<!-- Songs -->
	<assets path="assets/songs" library="songs" exclude="*.ogg" if="web" />
	<assets path="assets/songs" library="songs" exclude="*.ogg" if="ios" />
	<assets path="assets/songs" library="songs" exclude="*.mp3" if="android" />
	<assets path="assets/songs" library="songs" exclude="*.mp3" if="desktop" />

	<!-- Shared -->
	<assets path="assets/shared" library="shared" exclude="*.ogg" if="web" />
	<assets path="assets/shared" library="shared" exclude="*.ogg" if="ios" />
	<assets path="assets/shared" library="shared" exclude="*.mp3" if="android" />
	<assets path="assets/shared" library="shared" exclude="*.mp3" if="desktop" />

	<!-- Week 2 -->
	<assets path="assets/week2" library="week2" exclude="*.ogg" if="web" />
	<assets path="assets/week2" library="week2" exclude="*.ogg" if="ios" />
	<assets path="assets/week2" library="week2" exclude="*.mp3" if="android" />
	<assets path="assets/week2" library="week2" exclude="*.mp3" if="desktop" />

	<!-- Week 3 -->
	<assets path="assets/week3" library="week3" exclude="*.ogg" if="web" />
	<assets path="assets/week3" library="week3" exclude="*.ogg" if="ios" />
	<assets path="assets/week3" library="week3" exclude="*.mp3" if="android" />
	<assets path="assets/week3" library="week3" exclude="*.mp3" if="desktop" />

	<!-- Week 4 -->
	<assets path="assets/week4" library="week4" exclude="*.ogg" if="web" />
	<assets path="assets/week4" library="week4" exclude="*.ogg" if="ios" />
	<assets path="assets/week4" library="week4" exclude="*.mp3" if="android" />
	<assets path="assets/week4" library="week4" exclude="*.mp3" if="desktop" />

	<!-- Week 5 -->
	<assets path="assets/week5" library="week5" exclude="*.ogg" if="web" />
	<assets path="assets/week5" library="week5" exclude="*.ogg" if="ios" />
	<assets path="assets/week5" library="week5" exclude="*.mp3" if="android" />
	<assets path="assets/week5" library="week5" exclude="*.mp3" if="desktop" />

	<assets path="assets/fonts" embed="true" />
	<assets path="CHANGELOG.md" rename="changelog.txt" />

	<!-- ____________________________ Libraries ________________________________ -->

	<haxelib name="openfl"         />
	<haxelib name="lime"           />
	<haxelib name="flixel"         />
	<haxelib name="flixel-addons"  />
	<haxelib name="flixel-ui"      />
	<haxelib name="hscript"        />
	<haxelib name="actuate"        />
	<haxelib name="polymod"        />
	<haxelib name="newgrounds"     />
	<haxelib name="extension-webm" if="desktop" />
	<haxelib name="discord_rpc"    if="windows" />
	<haxelib name="faxe"           if="switch"  />

	<setenv name="next" if="web"     />
	<setenv name="next" if="desktop" />

	<!-- ___________________________ Haxe Defines _____________________________ -->

	<haxedef name="FLX_NO_MOUSE"              if="mobile"  />
	<haxedef name="FLX_NO_KEYBOARD"           if="mobile"  />
	<haxedef name="FLX_NO_TOUCH"              if="desktop" />
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN"              />
	<haxedef name="FLX_NO_DEBUG"              unless="debug" />
	<haxedef name="NAPE_RELEASE_BUILD"        unless="debug" />
	<haxedef name="HXCPP_STACK_SIZE" value="65536" if="android" />
	<haxedef name="NG_LOGIN"                  if="newgrounds" />

	<!-- _______________________________ Icons _________________________________ -->

	<icon path="art/icon16.png" size="16" />
	<icon path="art/icon32.png" size="32" />
	<icon path="art/icon64.png" size="64" />
	<icon path="art/iconOG.png"            />

</project>
